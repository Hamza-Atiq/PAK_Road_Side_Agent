# ============================================================
# RoadSide Agent — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# ============================================================

# ---------- App ----------
APP_NAME=roadside-agent
APP_ENV=development                 # development | staging | production
APP_BASE_URL=http://localhost:8000
DEBUG=true
LOG_LEVEL=INFO

# ---------- Database (PostgreSQL + PostGIS) ----------
# Async URL for the FastAPI app
DATABASE_URL=postgresql+asyncpg://roadside:roadside@localhost:5432/roadside
# Sync URL for Alembic migrations
DATABASE_SYNC_URL=postgresql://roadside:roadside@localhost:5432/roadside
POSTGRES_USER=roadside
POSTGRES_PASSWORD=roadside
POSTGRES_DB=roadside

# ---------- Redis (Celery broker + result backend) ----------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---------- JWT ----------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-only-please-change-me-32-bytes-min-length-required
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Anthropic Claude ----------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxx
# Default model for all agents. Update as new models release.
CLAUDE_MODEL=claude-sonnet-4-6

# ---------- OpenRouteService (free OSM-based routing) ----------
# Sign up at https://openrouteservice.org/dev/#/signup
ORS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ORS_BASE_URL=https://api.openrouteservice.org

# ---------- Twilio ----------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15551234567
TWILIO_WHATSAPP_NUMBER=whatsapp:+15551234567
# Twilio Verify Service SID for OTP phone verification
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Public base URL that Twilio will hit for delivery callbacks
TWILIO_CALLBACK_BASE_URL=https://your-domain.com

# ---------- File uploads ----------
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10
ALLOWED_IMAGE_MIME=image/jpeg,image/png,image/webp
ALLOWED_AUDIO_MIME=audio/mpeg,audio/mp4,audio/wav,audio/webm,audio/ogg

# ---------- CORS (comma-separated origins) ----------
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003

# ---------- Rate limits ----------
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_INCIDENT=5/minute

# ---------- Guardrail policy ----------
ABUSE_SUSPEND_THRESHOLD=5
ABUSE_WINDOW_HOURS=24

# ---------- Dispatch policy ----------
DISPATCH_INITIAL_RADIUS_KM=50
DISPATCH_MAX_RADIUS_KM=100
PROVIDER_OFFLINE_THRESHOLD_SECONDS=90
ASSIGNED_TIMEOUT_MINUTES=60
EN_ROUTE_TIMEOUT_MINUTES=180

# ---------- Backups ----------
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_RETENTION_DAYS=30

# ---------- Monitoring ----------
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
