# Railway-specific Dockerfile. The original backend/Dockerfile is kept as-is
# for docker-compose dev. This image is what Railway builds for production.
#
# Differences vs base Dockerfile:
#   - Non-root user
#   - Healthcheck via curl
#   - Honors Railway's injected $PORT
#   - CMD designed to be overridden per Railway service (api / worker / beat)

FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PORT=8000

RUN apt-get update && apt-get install -y --no-install-recommends \
        libmagic1 \
        libpq5 \
        curl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Backend code lives at /app
COPY requirements.txt .
RUN pip install --upgrade pip && pip install -r requirements.txt

COPY . .

# Non-root user for safety
RUN useradd -r -u 1001 -g root app && chown -R 1001:0 /app
USER 1001

EXPOSE 8000

# SERVICE_ROLE controls which process runs:
#   api (default) — Uvicorn HTTP server
#   worker        — Celery task worker
#   beat          — Celery periodic scheduler
# Healthcheck is only meaningful for the api role; worker/beat skip it.
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD if [ "${SERVICE_ROLE:-api}" = "api" ]; then curl -f http://127.0.0.1:${PORT}/health || exit 1; else exit 0; fi

CMD ["sh", "-c", "\
  if [ \"${SERVICE_ROLE:-api}\" = \"worker\" ]; then \
    exec celery -A celery_worker worker --loglevel=info --concurrency=4 -Q incidents,notifications,monitoring; \
  elif [ \"${SERVICE_ROLE:-api}\" = \"beat\" ]; then \
    exec celery -A celery_worker beat --loglevel=info; \
  else \
    exec uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000} --workers ${WEB_CONCURRENCY:-4}; \
  fi"]
