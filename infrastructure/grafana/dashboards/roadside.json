          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "Prometheus"},
          "expr": "histogram_quantile(0.95, sum(rate(incident_processing_seconds_bucket[5m])) by (le))",
