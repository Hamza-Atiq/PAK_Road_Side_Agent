        {
          "datasource": {"type": "prometheus", "uid": "Prometheus"},
          "expr": "rate(incidents_no_provider_total[5m])",
          "legendFormat": "no_provider",
          "refId": "C"
        }
      ],
      "title": "Incident Throughput (per second, 5m rate)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
