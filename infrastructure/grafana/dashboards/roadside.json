        {
          "datasource": {"type": "prometheus", "uid": "Prometheus"},
          "expr": "histogram_quantile(0.99, sum(rate(incident_processing_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
